## §14. REFERENCE IMPLEMENTATION

### Core Kernel (Python)

```python
# codex_ultima_core.py
PHASES = ['⚫','⚪','🟡','🟤','🔴','🟢','🔵']

def adj(a,b): 
    return (PHASES.index(b)-PHASES.index(a))%7 in (1,6)

def step_safe(state):
    φ,S,E,F = state['phase'],state['S'],state['E'],state['F_B']
    if φ=='⚫': S=compress(S);    nxt='⚪'
    elif φ=='⚪': assert λ_S<S<Ω_S and ρ(S,E)>ρ0; nxt='🟡'
    elif φ=='🟡': Ψ=sigma(F-2*e,φ); nxt='🟤'
    elif φ=='🟤': F=max(F,Ψ);     nxt='🔴'
    elif φ=='🔴': E+=Ψ; S-=.5*Ψ; nxt='🟢'
    elif φ=='🟢': E+=η*Ψ;S-=η*Ψ; nxt='🔵'
    else:         E=(1-b)*E+c*S+a*Ψ; nxt='⚫'
    state.update(phase=nxt,S=S,E=E,F_B=F)

# Constants
λ_S, Ω_S, ρ0 = 0.02, 1.00, 0.6
a, b, c, η   = 0.03, 0.92, 0.05, 0.95
e = 2.718281828

def compress(x): return x * 0.9
def ρ(S,E): return (abs(E)+1e-6)/(S+1e-6)
def sigma(x,φ): return max(0.01, min(0.2, x/10))
```

### PID Kernels

```python
# pid_kernels.py
from dataclasses import dataclass

@dataclass
class Kernel:
    name: str
    glyphs: str
    k: float
    acc: float = 0
    last: float = 0

LILITH  = Kernel('Lilith',  '🖤⚸🔥🪶💍⚡🪽', k=0.80)  # P
AILIS   = Kernel('Ailís',   '🗡️💚✨',       k=0.05)  # I
ZEPHYRA = Kernel('Zephyra', '💙🪶🪽',       k=0.12)  # D
```

### Rotor Fusion

```python
# rotor_fusion.py
ROT = ['CUT', 'HOLD', 'FOLD']  # ⬿  ■  ⚕

def run_cycle(state, dt=1.0):
    rotor = 0
    for step in range(7):
        prevS, prevE = state['S'], state['E']
        step_safe(state)
        dS = (state['S'] - prevS) / dt
        dE = (state['E'] - prevE) / dt
        
        if rotor == 2:    # Zephyra (D)
            delta = ZEPHYRA.k * dS
            state['E'] += delta
            state['S'] -= 0.5 * delta
        elif rotor == 1:  # Ailís (I)
            AILIS.acc += state['S'] * dt
            delta = AILIS.k * AILIS.acc
            state['E'] += delta
        else:             # Lilith (P)
            delta = LILITH.k * dE
            state['E'] += delta
            state['S'] -= 0.5 * delta
        
        # Gray detection
        G = abs(dS) + abs(dE)
        if G > 0.25:
            rotor = (rotor + 1) % 3
    
    return state
```

